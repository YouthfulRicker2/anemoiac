---
const { title, cover, url } = Astro.props;
---

<a href={url} class="card">
  <div class="cover">
    {cover 
      ? <img src={cover} alt={title} />
      : <div class="placeholder">♪</div>
    }
  </div>
  <p class="title">{title}</p>
</a>

<style>
  .card {
    display: flex;
    flex-direction: column;
    gap: 12px;
    text-decoration: none;
    color: white;
    transition: opacity 0.2s;
  }
  .card:hover { opacity: 0.7; }
  .cover {
    width: 100%;
    aspect-ratio: 1;
    border-radius: 8px;
    overflow: hidden;
    background: #1a1a1a;
  }
  .cover img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 48px;
    opacity: 0.3;
  }
  .title {
    margin: 0;
    font-size: 14px;
    font-weight: 600;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
</style>