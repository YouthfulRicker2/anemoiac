---
import Layout from "../../components/Layout.astro";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const releases = await getCollection("releases");
  return releases.map((release) => ({
    params: { slug: release.id },
    props: { release }
  }));
}

const { release } = Astro.props;
const { Content } = await render(release);
---

<Layout>
  <div class="release">
    <div class="cover">
      {release.data.cover
        ? <img src={release.data.cover} alt={release.data.title} />
        : <div class="placeholder">♪</div>
      }
    </div>
    <div class="info">
      <p class="label">Single</p>
      <h1>{release.data.title}</h1>
      <p class="date">{release.data.date}</p>
      <div class="description"><Content /></div>
      <div class="links">
        {release.data.spotify && (
          <a href={release.data.spotify} class="btn spotify">Spotify</a>
        )}
        {release.data.soundcloud && (
          <a href={release.data.soundcloud} class="btn soundcloud">SoundCloud</a>
        )}
      </div>
    </div>
  </div>
</Layout>

<style>
  .release {
    display: flex;
    gap: 48px;
    align-items: flex-start;
  }
  .cover {
    width: 280px;
    min-width: 280px;
    aspect-ratio: 1;
    border-radius: 8px;
    overflow: hidden;
    background: #1a1a1a;
    box-shadow: 0 8px 48px rgba(0,0,0,0.6);
  }
  .cover img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 64px;
    opacity: 0.3;
  }
  .info {
    display: flex;
    flex-direction: column;
    gap: 12px;
    padding-top: 16px;
  }
  .label {
    margin: 0;
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 2px;
    opacity: 0.5;
  }
  h1 {
    margin: 0;
    font-size: 48px;
    letter-spacing: -1px;
  }
  .date {
    margin: 0;
    opacity: 0.5;
    font-size: 14px;
  }
  .description {
    opacity: 0.8;
    font-size: 15px;
    line-height: 1.6;
    max-width: 500px;
  }
  .links {
    display: flex;
    gap: 12px;
    margin-top: 8px;
  }
  .btn {
    padding: 10px 24px;
    border-radius: 999px;
    text-decoration: none;
    font-size: 14px;
    font-weight: 600;
  }
  .spotify { background: #1DB954; color: black; }
  .soundcloud { background: #ff5500; color: white; }

  @media (max-width: 600px) {
    .release { flex-direction: column; }
    .cover { width: 100%; min-width: unset; }
    h1 { font-size: 32px; }
  }
</style>