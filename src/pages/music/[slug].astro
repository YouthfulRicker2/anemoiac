---
import Layout from "../../components/Layout.astro";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const releases = await getCollection("releases");
  return releases.map((release) => ({
    params: { slug: release.id },
    props: { release }
  }));
}

const { release } = Astro.props;
const { Content } = await render(release);
---

<Layout>
  <div class="release">
    <div class="cover">
      {release.data.cover
        ? <img src={release.data.cover} alt={release.data.title} />
        : <div class="placeholder">♪</div>
      }
    </div>
    <div class="info">
      <p class="label">Single</p>
      <h1>{release.data.title}</h1>
      <p class="date">{release.data.date}</p>
      <div class="description"><Content /></div>
      <div class="links">
		  {release.data.bandcamp && (
			<a href={release.data.bandcamp} class="btn bandcamp" target="_blank">
			  <img src="/icons/bandcamp.svg" alt="Bandcamp" class="icon" />
			  <span>Listen on Bandcamp</span>
			</a>
		  )}
		  {release.data.spotify && (
			<a href={release.data.spotify} class="btn spotify" target="_blank">
			  <img src="/icons/spotify.svg" alt="Spotify" class="icon" />
			  <span>Listen on Spotify</span>
			</a>
		  )}
		  {release.data["apple-music"] && (
			<a href={release.data["apple-music"]} class="btn apple-music" target="_blank">
			  <img src="/icons/applemusic.svg" alt="Apple Music" class="icon" />
			  <span>Listen on Apple Music</span>
			</a>
		  )}
		  {release.data["youtube-music"] && (
			<a href={release.data["youtube-music"]} class="btn youtube-music" target="_blank">
			  <img src="/icons/youtubemusic.svg" alt="YouTube Music" class="icon" />
			  <span>Listen on YouTube Music</span>
			</a>
		  )}
		  {release.data.soundcloud && (
			<a href={release.data.soundcloud} class="btn soundcloud" target="_blank">
			  <img src="/icons/soundcloud.svg" alt="SoundCloud" class="icon" />
			  <span>Listen on SoundCloud</span>
			</a>
		  )}
		  {release.data.tidal && (
			<a href={release.data.tidal} class="btn tidal" target="_blank">
			  <img src="/icons/tidal.svg" alt="Tidal" class="icon" />
			  <span>Listen on Tidal</span>
			</a>
		  )}
		  {release.data["amazon-music"] && (
			<a href={release.data["amazon-music"]} class="btn amazon-music" target="_blank">
			  <img src="/icons/amazon.svg" alt="Amazon Music" class="icon" />
			  <span>Listen on Amazon Music</span>
			</a>
		  )}
		  {release.data.deezer && (
			<a href={release.data.deezer} class="btn deezer" target="_blank">
			  <img src="/icons/deezer.svg" alt="Deezer" class="icon" />
			  <span>Listen on Deezer</span>
			</a>
		  )}
		  {release.data.qobuz && (
			<a href={release.data.qobuz} class="btn qobuz" target="_blank">
			  <img src="/icons/qobuz.svg" alt="Qobuz" class="icon" />
			  <span>Listen on Qobuz</span>
			</a>
		  )}
		  {release.data.anghami && (
			<a href={release.data.anghami} class="btn anghami" target="_blank">
			  <img src="/icons/anghami.svg" alt="Anghami" class="icon" />
			  <span>Listen on Anghami</span>
			</a>
		  )}
		</div>
    </div>
  </div>
</Layout>

<style>
  .release {
    display: flex;
    gap: 48px;
    align-items: flex-start;
  }
  .cover {
    width: 280px;
    min-width: 280px;
    aspect-ratio: 1;
    border-radius: 8px;
    overflow: hidden;
    background: #1a1a1a;
    box-shadow: 0 8px 48px rgba(0,0,0,0.6);
  }
  .cover img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 64px;
    opacity: 0.3;
  }
  .info {
    display: flex;
    flex-direction: column;
    gap: 12px;
    padding-top: 16px;
  }
  .label {
    margin: 0;
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 2px;
    opacity: 0.5;
  }
  h1 {
    margin: 0;
    font-size: 48px;
    letter-spacing: -1px;
  }
  .date {
    margin: 0;
    opacity: 0.5;
    font-size: 14px;
  }
  .description {
    opacity: 0.8;
    font-size: 15px;
    line-height: 1.6;
    max-width: 500px;
  }
  .links {
    display: flex;
    flex-direction: column;
    gap: 12px;
    margin-top: 16px;
    width: 100%;
    max-width: 400px;
  }
  .links {
	  display: flex;
	  flex-direction: column;
	  gap: 12px;
	  margin-top: 16px;
	  width: 100%;
	  max-width: 400px;
	}
  .btn {
    display: flex;
    align-items: center;
    gap: 16px;
    padding: 14px 20px;
    border-radius: 12px;
    text-decoration: none;
    font-size: 15px;
    font-weight: 600;
    transition: transform 0.15s, opacity 0.15s;
    background: #0f0f0f;
    border: 1px solid;
  }
  .btn:hover { transform: scale(1.02); opacity: 0.9; }
  .icon { width: 24px; height: 24px; flex-shrink: 0; }

  .spotify       { color: #1DB954; border-color: #1DB954; }
  .apple-music   { color: #fc3c44; border-color: #fc3c44; }
  .youtube-music { color: #FF0000; border-color: #FF0000; }
  .soundcloud    { color: #ff5500; border-color: #ff5500; }
  .bandcamp      { color: #1da0c3; border-color: #1da0c3; }
  .tidal         { color: #ffffff; border-color: #ffffff; }
  .deezer        { color: #A238FF; border-color: #A238FF; }
  .qobuz         { color: #ffffff; border-color: #ffffff; }
  .anghami       { color: #F62B54; border-color: #F62B54; }
  .amazon-music  { color: #25D1DA; border-color: #25D1DA; }
  
  .icon { width: 24px; height: 24px; flex-shrink: 0; filter: brightness(0) invert(1); }

  .spotify       .icon { filter: invert(58%) sepia(69%) saturate(456%) hue-rotate(95deg) brightness(96%) contrast(88%); }
  .apple-music   .icon { filter: invert(35%) sepia(90%) saturate(800%) hue-rotate(330deg) brightness(110%) contrast(95%); }
  .youtube-music .icon { filter: invert(15%) sepia(95%) saturate(7000%) hue-rotate(0deg) brightness(105%) contrast(115%); }
  .soundcloud    .icon { filter: invert(45%) sepia(98%) saturate(1200%) hue-rotate(1deg) brightness(103%) contrast(104%); }
  .bandcamp      .icon { filter: invert(50%) sepia(60%) saturate(500%) hue-rotate(160deg) brightness(95%) contrast(90%); }
  .tidal         .icon { filter: brightness(0) invert(1); }
  .deezer        .icon { filter: invert(40%) sepia(80%) saturate(600%) hue-rotate(240deg) brightness(105%) contrast(100%); }
  .qobuz         .icon { filter: brightness(0) invert(1); }
  .anghami       .icon { filter: invert(27%) sepia(90%) saturate(1500%) hue-rotate(325deg) brightness(105%) contrast(100%); }
  .amazon-music  .icon { filter: invert(75%) sepia(60%) saturate(400%) hue-rotate(150deg) brightness(100%) contrast(95%); }

  @media (max-width: 600px) {
    .release { flex-direction: column; }
    .cover { width: 100%; min-width: unset; }
    h1 { font-size: 32px; }
  }
</style>