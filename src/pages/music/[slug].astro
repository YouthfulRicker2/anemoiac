---
import Layout from "../../components/Layout.astro";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const releases = await getCollection("releases");
  return releases.map((release) => ({
    params: { slug: release.id },
    props: { release }
  }));
}

const { release } = Astro.props;
const { Content } = await render(release);
---

<Layout>
  <div class="release">
    <div class="cover">
      {release.data.cover
        ? <img src={release.data.cover} alt={release.data.title} />
        : <div class="placeholder">♪</div>
      }
    </div>
    <div class="info">
      <p class="label">Single</p>
      <h1>{release.data.title}</h1>
      <p class="date">{release.data.date}</p>
      <div class="description"><Content /></div>
      <div class="links">
		  {release.data.spotify && (
			<a href={release.data.spotify} class="btn spotify">
			  <img src="/icons/spotify.svg" alt="Spotify" class="icon" />
			  <span>Listen on Spotify</span>
			</a>
		  )}
		  {release.data.soundcloud && (
			<a href={release.data.soundcloud} class="btn soundcloud">
			  <img src="/icons/soundcloud.svg" alt="SoundCloud" class="icon" />
			  <span>Listen on SoundCloud</span>
			</a>
		  )}
		</div>
    </div>
  </div>
</Layout>

<style>
  .release {
    display: flex;
    gap: 48px;
    align-items: flex-start;
  }
  .cover {
    width: 280px;
    min-width: 280px;
    aspect-ratio: 1;
    border-radius: 8px;
    overflow: hidden;
    background: #1a1a1a;
    box-shadow: 0 8px 48px rgba(0,0,0,0.6);
  }
  .cover img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 64px;
    opacity: 0.3;
  }
  .info {
    display: flex;
    flex-direction: column;
    gap: 12px;
    padding-top: 16px;
  }
  .label {
    margin: 0;
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 2px;
    opacity: 0.5;
  }
  h1 {
    margin: 0;
    font-size: 48px;
    letter-spacing: -1px;
  }
  .date {
    margin: 0;
    opacity: 0.5;
    font-size: 14px;
  }
  .description {
    opacity: 0.8;
    font-size: 15px;
    line-height: 1.6;
    max-width: 500px;
  }
  .links {
    display: flex;
    flex-direction: column;
    gap: 12px;
    margin-top: 16px;
    width: 100%;
    max-width: 400px;
  }
  .btn {
    display: flex;
    align-items: center;
    gap: 16px;
    padding: 14px 20px;
    border-radius: 12px;
    text-decoration: none;
    font-size: 15px;
    font-weight: 600;
    transition: transform 0.15s, opacity 0.15s;
  }
  .btn:hover {
    transform: scale(1.02);
    opacity: 0.9;
  }
  .icon {
    width: 24px;
    height: 24px;
    flex-shrink: 0;
  }
  .spotify { background: #0f0f0f; color: #1DB954; border: 1px solid #1DB954; }
  .spotify .icon { filter: invert(58%) sepia(69%) saturate(456%) hue-rotate(95deg) brightness(96%) contrast(88%); }
  .soundcloud { background: #0f0f0f; color: #ff5500; border: 1px solid #ff5500; }
  .soundcloud .icon { filter: invert(45%) sepia(98%) saturate(1200%) hue-rotate(1deg) brightness(103%) contrast(104%); }

  @media (max-width: 600px) {
    .release { flex-direction: column; }
    .cover { width: 100%; min-width: unset; }
    h1 { font-size: 32px; }
  }
</style>